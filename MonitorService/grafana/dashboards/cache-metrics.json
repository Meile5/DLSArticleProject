      },
      "targets": [
        {
          "expr": "rate(articlecache_hits_total[1m]) / (rate(articlecache_hits_total[1m]) + rate(articlecache_misses_total[1m])) * 100",
          "legendFormat": "Hit Ratio %",
          "refId": "A"
